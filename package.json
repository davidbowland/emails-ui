{
  "name": "emails-ui",
  "version": "1.15.0",
  "description": "UI for emails",
  "author": "David Bowland",
  "engines": {
    "node": "^24.0.0"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidbowland/emails-ui.git"
  },
  "bugs": {
    "url": "https://github.com/davidbowland/emails-ui/issues"
  },
  "homepage": "https://github.com/davidbowland/emails-ui#readme",
  "scripts": {
    "build": "npm run clean && next build",
    "postbuild": "next-sitemap",
    "clean": "rm -rf .next coverage out && npm ci --legacy-peer-deps",
    "deploy": "DEVELOPMENT=true npm run build && ./scripts/deploy.sh",
    "lint": "prettier --write . && eslint --fix .",
    "prepare": "husky",
    "serve": "next build && npx serve out",
    "start": "next dev",
    "test": "jest --colors",
    "typecheck": "tsc --noEmit",
    "update": "npx update-browserslist-db@latest && ncu --doctor --target minor --upgrade && npm audit fix --audit-level=none && npm run test && npm dedupe"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^4.6.5",
    "@fontsource/roboto": "^4.5.8",
    "@heroui/react": "^3.0.1",
    "aws-amplify": "^5.3.33",
    "axios": "^1.14.0",
    "dompurify": "^3.3.3",
    "fast-json-patch": "^3.1.1",
    "framer-motion": "^12.38.0",
    "husky": "^9.1.7",
    "lucide-react": "^1.7.0",
    "next": "^15",
    "next-sitemap": "^4",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "universal-cookie": "^4.0.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/dompurify": "^3.2.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-jest": "^28.14.0",
    "eslint-plugin-react": "^7.37.5",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^13.3.0",
    "prettier": "^3.8.1",
    "react-test-renderer": "^19",
    "undici": "^6.24.1"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "prettier --write --ignore-unknown",
      "eslint --fix",
      "jest --colors --findRelatedTests --coverageThreshold '{}' --passWithNoTests"
    ],
    "**/*": [
      "prettier --write --ignore-unknown"
    ]
  }
}
